ANTHROPIC_API_KEY=your-api-key-here
SENDGRID_API_KEY=your-sendgrid-api-key-here
EMAIL_FROM=no-reply@yourdomain.com
LEADERSHIP_EMAILS=email1@example.com,email2@example.com
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token
# Firebase session token scraped from the Partiful web app — expires ~1h.
# Used by the /api/partiful/sync endpoint and the 2-hour auto-sync cron.
PARTIFUL_AUTH_TOKEN=your-partiful-firebase-jwt
# Partiful event ID to sync. If unset, the auto-sync cron stays disabled.
PARTIFUL_EVENT_ID=your-partiful-event-id
